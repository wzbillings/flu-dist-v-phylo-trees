#!/usr/bin/env bash
#
# pre-commit hook
#
# Blocks commits that would add or modify files with staged content
# greater than or equal to 100 MiB.
#
# This is intended to prevent accidentally committing files that exceed
# common Git hosting limits, such as GitHub's 100 MiB per-file limit.
#
# Install:
#
#   Save this file as .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Notes:
#
# - This checks staged file content, not the working tree.
# - Deleted files are ignored.
# - Renamed/copied files are checked using their staged destination path.
# - 100 MiB = 104,857,600 bytes.

set -euo pipefail

readonly MAX_FILE_SIZE_BYTES=$((100 * 1024 * 1024))
readonly MAX_FILE_SIZE_LABEL="100 MiB"

has_error=0

# Check files staged for add, copy, modify, rename, or type change.
# Use NUL delimiters so paths with spaces, quotes, or newlines are handled safely.
while IFS= read -r -d '' file_path; do
    # Skip paths that do not have a staged blob, such as unusual index states.
    if ! file_size_bytes="$(git cat-file -s ":${file_path}" 2>/dev/null)"; then
        continue
    fi

    if (( file_size_bytes >= MAX_FILE_SIZE_BYTES )); then
        if (( has_error == 0 )); then
            cat >&2 <<EOF
ERROR: Commit blocked because one or more staged files are ${MAX_FILE_SIZE_LABEL} or larger.

Large files should not be committed directly to this repository.
Use Git LFS, external storage, a generated-file workflow, or remove the file
from the commit before trying again.

Files at or above the limit:

EOF
        fi

        printf '  - %s (%s bytes)\n' "$file_path" "$file_size_bytes" >&2
        has_error=1
    fi
done < <(
    git diff --cached --name-only -z --diff-filter=ACMRT
)

if (( has_error != 0 )); then
    cat >&2 <<'EOF'

To unstage a file:

  git restore --staged <path>

To remove a file from the repository but keep it locally:

  git rm --cached <path>

Commit aborted.
EOF

    exit 1
fi

exit 0